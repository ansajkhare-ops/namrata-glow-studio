generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  name      String
  contact   String
  message   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
  status    String   @default("UNREAD")
}
